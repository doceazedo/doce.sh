{
	"name": "doceazedo.com",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "concurrently -n svelte,pocketbase -p name -c bgYellow,bgCyan 'pnpm vite dev' './pocketbase/pocketbase serve'",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"typegen": "pocketbase-typegen --env -o src/lib/pocketbase-types.ts",
		"build-and-publish": "docker buildx build --platform linux/amd64 --secret id=env,src=.env -t doceazedo/doce.sh:latest --push ."
	},
	"devDependencies": {
		"@eslint/compat": "^1.4.1",
		"@eslint/js": "^9.39.4",
		"@internationalized/date": "^3.12.1",
		"@lucide/svelte": "^0.515.0",
		"@poppanator/sveltekit-svg": "^5.0.1",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.61.1",
		"@sveltejs/vite-plugin-svelte": "^5.1.1",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.3.0",
		"@types/steam-user": "^5.1.1",
		"bits-ui": "^2.18.1",
		"clsx": "^2.1.1",
		"concurrently": "^9.2.1",
		"eslint": "^9.39.4",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.1",
		"globals": "^16.5.0",
		"mdsvex": "^0.12.7",
		"pocketbase-typegen": "^1.5.0",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.2",
		"prettier-plugin-tailwindcss": "^0.6.14",
		"simple-icons": "^15.22.0",
		"svelte": "^5.55.9",
		"svelte-check": "^4.4.8",
		"svelte-remix": "^3.0.1",
		"svelte-sonner": "^1.1.1",
		"tailwind-merge": "^3.6.0",
		"tailwind-variants": "^1.0.0",
		"tailwindcss": "^4.3.0",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.60.0",
		"vaul-svelte": "1.0.0-next.7",
		"vite": "^6.4.2"
	},
	"dependencies": {
		"@atproto/api": "^0.15.27",
		"@dimforge/rapier3d-compat": "^0.17.3",
		"@inlang/paraglide-js": "^2.18.1",
		"@neoconfetti/svelte": "^2.2.2",
		"@resvg/resvg-js": "^2.6.2",
		"@threlte/core": "^8.5.16",
		"@threlte/extras": "^9.20.1",
		"@threlte/rapier": "^3.5.0",
		"@threlte/studio": "^0.1.11",
		"@turf/turf": "^7.3.5",
		"@types/three": "^0.177.0",
		"feed": "^5.2.1",
		"fflate": "^0.8.3",
		"mapbox-gl": "^3.24.0",
		"mode-watcher": "^1.1.0",
		"pocketbase": "^0.27.0",
		"rehype-external-links": "^3.0.0",
		"rehype-slug": "^6.0.0",
		"remark-code-title": "^0.2.5",
		"remark-table-of-content": "^0.5.2",
		"remark-table-of-contents": "^2.1.0",
		"satori": "^0.15.2",
		"satori-html": "^0.3.2",
		"steam-user": "5.2.3",
		"three": "^0.177.0",
		"vite-plugin-arraybuffer": "^0.1.4"
	}
}
